# ===== 密钥 / 私密文件（绝不上传）=====
openrouter.env
*.env
!*.env.example
# Tauri 更新签名私钥（仅本机与 GitHub Secret 保存）
*.key
*.key.pub
*updater*.password.txt

# ===== 依赖 / 构建产物 =====
node_modules/
dist/
desktop-app/dist/
desktop-app/node_modules/

# ===== Rust / Tauri 构建产物 =====
desktop-app/src-tauri/target/
desktop-app/src-tauri/gen/

# ===== 移动端图标（仅发桌面端，tauri icon 顺带生成的不纳入）=====
desktop-app/src-tauri/icons/android/
desktop-app/src-tauri/icons/ios/

# ===== 内置 ffmpeg 二进制（体积大，CI 自动下载）=====
desktop-app/src-tauri/binaries/ffmpeg-*
desktop-app/src-tauri/binaries/ffprobe-*

# ===== 工作流运行产物 =====
runs/*/
inputs/*
products/*
!**/README.md
!**/.gitignore

# ===== 历史分析产物 / 大文件 =====
analysis_frames/
# 只忽略仓库根目录的 assets/（存放临时大图等）；不要误伤 desktop-app/src/assets/
/assets/
*.mp4
*.mov
*.mkv

# ===== 系统 / 编辑器 =====
.DS_Store
Thumbs.db
*.log
