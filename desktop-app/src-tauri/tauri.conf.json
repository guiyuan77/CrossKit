{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CrossKit",
  "version": "0.2.0",
  "identifier": "com.crosskit.toolbox",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "CrossKit 跨境工具箱",
        "width": 1024,
        "height": 720,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/ffmpeg", "binaries/ffprobe"]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDZFNDg5MzBDNzlDRjQzODQKUldTRVE4OTVESk5JYnU5UVFLeHhyUUxaUzdzeDB4Z3dJeFJESFRGaW14SW10Q3VLZlNSb1J1SUEK",
      "endpoints": [
        "https://github.com/guiyuan77/CrossKit/releases/latest/download/latest.json"
      ]
    }
  }
}
